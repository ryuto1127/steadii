# Database
DATABASE_URL=

# Auth.js
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Notion OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=

# Optional model overrides. Defaults in lib/agent/models.ts are
# gpt-5.4-mini / gpt-5.4 / gpt-5.4-nano. Set these if the default IDs
# aren't yet enabled on your OpenAI account — e.g. OPENAI_CHAT_MODEL=gpt-4o-mini
# during α. See memory/project_decisions.md for the authoritative model
# routing policy.
OPENAI_CHAT_MODEL=
OPENAI_COMPLEX_MODEL=
OPENAI_NANO_MODEL=

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Legacy single-price var, still referenced by /api/stripe/checkout until the
# multi-tier refactor lands. Set to the same value as STRIPE_PRICE_PRO_MONTHLY
# during the transition.
STRIPE_PRICE_ID_PRO=

# Multi-tier price IDs (created by `pnpm tsx scripts/stripe-setup.ts`).
# The script is idempotent: re-running it reuses existing products/prices
# matched by metadata and prints the env var lines to paste here.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_STUDENT_4MO=
STRIPE_PRICE_TOPUP_500=
STRIPE_PRICE_TOPUP_2000=
STRIPE_PRICE_DATA_RETENTION=

# Stripe Coupon IDs (also emitted by stripe-setup.ts). ADMIN grants 100% off
# forever for Ryuto's dogfood account; FRIEND_3MO backs individual single-use
# Promotion Codes (max_redemptions=1 each) for α invites and referrals.
STRIPE_COUPON_ADMIN=
STRIPE_COUPON_FRIEND_3MO=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Token encryption (32-byte base64 key)
ENCRYPTION_KEY=

# Vercel Blob (image + PDF uploads in chat and syllabus upload)
BLOB_READ_WRITE_TOKEN=

# App base URL (OAuth callback base)
APP_URL=http://localhost:3000
